# SuiPredict AI — Environment Variables
# Copy to .env and fill in your values

# =============================================================================
# CONTRACTS (required for all packages)
# =============================================================================

# Deployed prediction_market.move package ID
PREDICT_MARKET_PACKAGE_ID=

# FeeVault<DBUSDC> object ID (from contract deployment)
FEE_VAULT_ID=

# Protocol treasury address for referral rewards and protocol fees
REFERRAL_TREASURY_ADDRESS=

# =============================================================================
# DEEPBOOK V3 (required for SDK and agents)
# =============================================================================

# DeepBook V3 package ID on testnet
DEEPBOOK_PACKAGE_ID=0xdee9

# DeepBook Registry object ID on testnet
DEEPBOOK_REGISTRY_ID=0xe0ce

# Default pool key (used when market-specific pool key is not set)
PREDICT_DEEPBOOK_POOL_KEY=

# =============================================================================
# SUI NETWORK
# =============================================================================

# Sui testnet RPC URL (default: Mysten public)
SUI_RPC_URL=https://rpc.testnet.sui.io:443

# =============================================================================
# AGENTS (required for apps/agents)
# =============================================================================

# Agent's hot wallet private key (base58-encoded ed25519)
AGENT_PRIVATE_KEY=

# Market-maker only: comma-separated market IDs to run (omit to run all active)
# AGENT_MARKET_IDS=0x...,0x...

# Referral keeper only: override treasury (defaults to REFERRAL_TREASURY_ADDRESS)
# REFERRAL_TREASURY_ADDRESS=

# =============================================================================
# DATABASE (apps/agents — SQLite file path)
# =============================================================================

# Default: ./data/markets.db
# DATABASE_PATH=./data/markets.db

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info
