# SuiPredict AI — Environment Variables
# Copy to .env and fill in your values

# =============================================================================
# SUI NETWORK
# =============================================================================

# testnet | mainnet | devnet | localnet
SUI_NETWORK=testnet

# Optional explicit RPC URL (defaults to Mysten public endpoint for the
# SUI_NETWORK above). Override for self-hosted nodes or proxies.
# SUI_RPC_URL=https://rpc.testnet.sui.io:443

# =============================================================================
# CONTRACTS (required for all packages)
# =============================================================================

# Deployed `agent_policy` package ID. Published by `pnpm bootstrap` and
# contains: agent_policy, streak_system, prize_pool, prediction_market,
# registry, types, vault, vlp, parlay, badge_nft, user_profile.
AGENT_POLICY_PACKAGE_ID=

# Public (read-only) variant of the same package ID for the frontend.
NEXT_PUBLIC_MARKET_PACKAGE_ID=

# FeeVault<DBUSDC> object ID (from contract deployment)
FEE_VAULT_ID=

# Protocol treasury address for referral rewards and protocol fees
REFERRAL_TREASURY_ADDRESS=

# Self-hosted DUSDC package (defaults to Mysten testnet DUSDC).
# Set this to the package ID of your self-hosted dusdc package so the SDK
# constructs the right coin type.
DUSDC_PACKAGE_ID=

# TreasuryCap for the self-hosted DUSDC. Required by the bootstrap script
# to mint seed DUSDC for the prize pool.
DUSDC_TREASURY_CAP_ID=

# =============================================================================
# DEEPBOOK V3 (required for SDK and agents)
# =============================================================================

# DeepBook V3 package ID on testnet
DEEPBOOK_PACKAGE_ID=0xdee9

# DeepBook Registry object ID on testnet
DEEPBOOK_REGISTRY_ID=0xe0ce

# Default pool key (used when market-specific pool key is not set)
PREDICT_DEEPBOOK_POOL_KEY=

# =============================================================================
# AGENTS (required for apps/agents)
# =============================================================================

# Agent's hot wallet private key (base58-encoded ed25519)
AGENT_PRIVATE_KEY=

# Per-tx USDC budget cap used by the market-maker / referral agents.
# 1_000_000 = 1 DUSDC. Defaults to 50 DUSDC.
AGENT_MAX_BUDGET_USDC=50

# Poll interval for the position-indexer / leaderboard-worker (ms).
# Lower = fresher data, more RPC. Defaults to 5000ms.
AGENT_POLL_INTERVAL_MS=5000

# =============================================================================
# GAMIFICATION (set by `pnpm --filter @suipredict/agents bootstrap`)
# =============================================================================

# StreakAdmin shared object ID (created at module init).
STREAK_ADMIN_ID=

# StreakRegistry shared object ID (created at module init).
STREAK_REGISTRY_ID=

# PrizeAdmin shared object ID (created at module init).
PRIZE_ADMIN_ID=

# PrizePool<DBUSDC> shared object ID (created by `prize_pool::create_pool`).
PRIZE_POOL_ID=

# PrizeAdmin ed25519 private key (base64). Signs weekly claim payloads.
PRIZE_ADMIN_PRIVATE_KEY=

# Weekly prize amount in DUSDC base units (1_000_000 = 1 DUSDC).
PRIZE_WEEKLY_AMOUNT=1000000000

# Auto-claim on behalf of winners (true for custodial demo, false for production).
PRIZE_AUTO_CLAIM=false

# Market-maker only: comma-separated market IDs to run (omit to run all active)
# AGENT_MARKET_IDS=0x...,0x...

# Agent policy object ID (set by /settings page after creating a policy)
AGENT_POLICY_ID=

# Agent manager address (the owner of the policy who can pause / revoke)
AGENT_MANAGER_ID=

# =============================================================================
# PARLAY (set by `pnpm --filter @suipredict/agents bootstrap-parlay`)
# =============================================================================

# ParlayPool<DBUSDC> shared object ID (created by
# `parlay::create_pool`). The web `/parlay` page reads this to know
# which pool to lock collateral against.
PARLAY_POOL_ID=
NEXT_PUBLIC_PARLAY_POOL_ID=

# Per-parlay multiplier cap in bps (10_000 = 1x). Defaults to 50_000 = 5x.
# Anything higher is a bigger payout ceiling and a bigger worst-case
# pool exposure.
NEXT_PUBLIC_PARLAY_MAX_PAYOUT_BPS=50000

# Optional dUSDC seed for the parlay pool, base units (1_000_000 = 1 DUSDC).
# Set to 0 to skip the seed at bootstrap time and fund later via fund_pool.
PARLAY_SEED_AMOUNT=0

# =============================================================================
# PROFILE (user_profile module — published with agent_policy)
# =============================================================================

# ProfileRegistry shared object ID (created at user_profile::init).
NEXT_PUBLIC_PROFILE_REGISTRY_ID=

# =============================================================================
# SERVER (apps/agents)
# =============================================================================

# HTTP port the agents process listens on. Defaults to 3001.
PORT=3001

# OpenAI API key (used by the LLM-powered market creator / analyst).
# Leave blank to fall back to the deterministic mock generators.
OPENAI_API_KEY=

# Enable the legacy DeepBook-Predict agent set (only needed if you also
# run the older /predict routes alongside the CLOB markets). Default false.
ENABLE_LEGACY_PREDICT_AGENTS=false

# =============================================================================
# DATABASE (apps/agents — SQLite file path)
# =============================================================================

# Default: ./data/markets.db
# DATABASE_PATH=./data/markets.db

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# ADVANCED (rarely tuned — defaults baked in for the demo)
# =============================================================================

# DeepBook V3 BalanceManager id (or a file path that contains it).
# bootstrap-gamification writes this on first run; the market-maker
# reads it directly. BALANCE_MANAGER_ID_FILE wins if both are set
# (used for k8s secret-mounted file paths).
BALANCE_MANAGER_ID=
BALANCE_MANAGER_ID_FILE=

# Full dUSDC type string. Defaults to <DUSDC_PACKAGE_ID>::dusdc::DUSDC.
# Overriding this changes the type arg for every prediction_market /
# parlay PTB; only set if you have a non-default dusdc package.
DUSDC_TYPE=

# Resolver confidence threshold (0-100). The market-resolver agent
# only commits a resolution when its self-check exceeds this. Lower
# values resolve more aggressively but risk more disputes.
RESOLVER_CONFIDENCE=85

# Risk monitor pause utilization. When the protocol's market-maker
# exposure exceeds this fraction of the prize pool, the risk monitor
# pauses new market-creator / market-maker actions until exposure
# drops back below. Defaults to 0.80.
RISK_PAUSE_UTILIZATION=0.80

# Market-creator initial mint size in atoms (DUSDC has 6 decimals,
# 1_000_000 = 1 DUSDC). Defaults to 10_000_000 (10 DUSDC).
MARKET_CREATOR_INITIAL_MINT_ATOMS=10000000

# Market-maker quote size per side, in atoms. Defaults to 10_000_000
# (10 DUSDC). The maker places 1 bid + 1 ask of this size on every
# tick when the spread exceeds MM_SPREAD_THRESHOLD_BPS.
MM_QUOTE_SIZE=10000000

# Min market spread (bps) before the market-maker re-quotes. Defaults
# to 50 bps (0.5%).
MM_SPREAD_THRESHOLD_BPS=50

# Max active markets the market-creator will spin up at once.
# Defaults to 5; the cron picks the next expiry from this pool.
MAX_ACTIVE_MARKETS=5

# Prize distributor: amount to fund the pool with on first weekly
# claim. Defaults to PRIZE_WEEKLY_AMOUNT. Set to 0 to disable
# auto-funding (operator funds manually).
PRIZE_FUND_AMOUNT=1000000000

# Prize distributor: skip a week if the on-chain pool balance is
# below this many atoms. Defaults to 0 (always run).
PRIZE_POOL_MIN_BALANCE=0

# Vault summary overrides (for hosts where the live on-chain
# read isn't available — typically empty in production).
VAULT_TOTAL_BALANCE=
VAULT_ALLOCATED=

