# Local development — copy to .env and fill in secrets

SUI_NETWORK=testnet

# Export with: sui keytool export --key-identity <your-address>
AGENT_PRIVATE_KEY=

# From smoke-test output
AGENT_MANAGER_ID=0xd8fe2007b3e71060720c2b13e5a0e8a1761bdb8d94fafe86b14c2fa4fcdd8b87

# From Settings → Create Policy (shared object — republish v2 package required)
AGENT_POLICY_ID=

AGENT_POLICY_PACKAGE_ID=0x7377808da2e3d48282268c56e332ac282adca02db3a4d924505fa139067ff4e8

OPENAI_API_KEY=
AGENT_POLL_INTERVAL_MS=15000
AGENT_MAX_BUDGET_USDC=500

# Demo: rule-based mints when LLM unavailable (requires dUSDC)
DEMO_AUTO_TRADE=false

# Agent thresholds (tuned for testnet ~0.1% utilization)
PLP_HIGH_UTILIZATION=0.001
PLP_LOW_UTILIZATION=0.0005
PLP_SUPPLY_AMOUNT=1
RISK_PAUSE_UTILIZATION=0.002

NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_AGENTS_URL=http://localhost:3001
NEXT_PUBLIC_PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
