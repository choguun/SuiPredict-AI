# Local development — copy to .env and fill in secrets

SUI_NETWORK=testnet

# Export with: sui keytool export --key-identity <your-address>
AGENT_PRIVATE_KEY=

# Legacy Predict (optional — ENABLE_LEGACY_PREDICT_AGENTS=true)
AGENT_MANAGER_ID=0xd8fe2007b3e71060720c2b13e5a0e8a1761bdb8d94fafe86b14c2fa4fcdd8b87
AGENT_POLICY_ID=
AGENT_POLICY_PACKAGE_ID=0x7377808da2e3d48282268c56e332ac282adca02db3a4d924505fa139067ff4e8
ENABLE_LEGACY_PREDICT_AGENTS=false

# CLOB markets (after publish + init registry/vault)
MARKET_PACKAGE_ID=0x7377808da2e3d48282268c56e332ac282adca02db3a4d924505fa139067ff4e8
MARKET_REGISTRY_ID=
VAULT_OBJECT_ID=
VLP_TREASURY_CAP_ID=
MAX_ACTIVE_MARKETS=5
MM_SPREAD_THRESHOLD_BPS=400
MM_QUOTE_SIZE=10000000
RESOLVER_CONFIDENCE=85
DEEP_POOL_CREATION_BUDGET=500

OPENAI_API_KEY=
AGENT_POLL_INTERVAL_MS=15000
AGENT_MAX_BUDGET_USDC=500

# Demo vault stats (when VAULT_OBJECT_ID unset)
VAULT_TOTAL_BALANCE=1000000000
VAULT_ALLOCATED=200000000

# Legacy Predict demo
DEMO_AUTO_TRADE=false
PLP_HIGH_UTILIZATION=0.001
PLP_LOW_UTILIZATION=0.0005
PLP_SUPPLY_AMOUNT=1
RISK_PAUSE_UTILIZATION=0.002

NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_AGENTS_URL=http://localhost:3001
NEXT_PUBLIC_PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
NEXT_PUBLIC_MARKET_PACKAGE_ID=0x7377808da2e3d48282268c56e332ac282adca02db3a4d924505fa139067ff4e8
NEXT_PUBLIC_VAULT_OBJECT_ID=
