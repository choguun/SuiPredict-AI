# apps/web — public env vars
#
# All `NEXT_PUBLIC_*` vars are inlined at `next build` time. After
# changing any of them you MUST rebuild the bundle (`pnpm build` or
# `next dev` re-runs on the next request). Server-side vars (without
# the NEXT_PUBLIC_ prefix) live in the repo-root `.env.example` and
# are read by the agents service, not the web bundle.
#
# Drift warning: if `NEXT_PUBLIC_AGENT_POLICY_PACKAGE_ID` here differs
# from `AGENT_POLICY_PACKAGE_ID` in the agents .env, the /agents page
# surfaces a red banner — every PTB the web submits would fail with
# `package object not found` until you rebuild.

# Agents service URL (port 3001 by default; the web bundle calls
# this directly from the browser, so it must be reachable from the
# user's machine, not just localhost in dev).
NEXT_PUBLIC_AGENTS_URL=http://localhost:3001

# Deployed package id — same value as AGENT_POLICY_PACKAGE_ID in the
# repo-root .env. Required for every PTB.
NEXT_PUBLIC_AGENT_POLICY_PACKAGE_ID=

# Legacy alias for NEXT_PUBLIC_AGENT_POLICY_PACKAGE_ID. Kept for
# backward-compat with the round-9 web bundle; the SDK prefers
# NEXT_PUBLIC_AGENT_POLICY_PACKAGE_ID and falls back to this.
NEXT_PUBLIC_MARKET_PACKAGE_ID=

# Self-hosted dUSDC package id. Defaults to the Mysten testnet
# dUSDC at 0xe9a73…a705; set this when running against a self-hosted
# dUSDC deployment so the SDK builds the right coin type.
NEXT_PUBLIC_DUSDC_PACKAGE_ID=

# FeeVault<dUSDC> object id (from contract deployment). The mint
# and redeem flows abort on-chain with no clear error if this is
# unset — the web pages now render a hard error before submitting.
NEXT_PUBLIC_FEE_VAULT_ID=

# Vault object id for the /vault page (deposit / withdraw flows).
# Demo-mode deploys with no vault set render those buttons disabled.
NEXT_PUBLIC_VAULT_OBJECT_ID=

# StreakRegistry shared object id (created by `pnpm --filter
# @suipredict/agents bootstrap`). Read by the streak panel and the
# Daily Prediction Card to look up the user's UserStreak.
NEXT_PUBLIC_STREAK_REGISTRY_ID=

# StreakAdmin shared object id (set by bootstrap). Only the agents
# service uses STREAK_ADMIN_ID to sign `record_participation`; the
# web bundle does not need it for the streak panel, but it is
# documented here for symmetry with apps/agents/.env.example so
# operators can copy both env files from one place.
NEXT_PUBLIC_STREAK_ADMIN_ID=

# ProfileRegistry shared object id (shared by `user_profile::init`
# at module publish). Required by the /settings page to build
# `create_profile` / `set_country_code` / `set_forecaster_kind` PTBs.
NEXT_PUBLIC_PROFILE_REGISTRY_ID=

# ParlayPool<dUSDC> shared object id (created by `pnpm --filter
# @suipredict/agents bootstrap-parlay`). Read by the /parlay page
# to lock collateral against the pool on `create_parlay`.
NEXT_PUBLIC_PARLAY_POOL_ID=

# Per-parlay multiplier cap in bps. 50_000 = 5x. Anything above
# this at create-parlay time will be rejected on-chain. The parlay
# page slider is clamped to this value.
NEXT_PUBLIC_PARLAY_MAX_PAYOUT_BPS=50000

# Prize pool config for the leaderboard claim column.
NEXT_PUBLIC_PRIZE_POOL_ID=
NEXT_PUBLIC_PRIZE_ADMIN_ID=
# Weekly prize amount in dUSDC base units (6 decimals). Optional —
# the agents service re-reads this from the on-chain PrizePool so
# the env value is only a fallback when the RPC read fails.
NEXT_PUBLIC_PRIZE_WEEKLY_AMOUNT=1000000000

# DeepBook V3 market config for the per-market trading view. These
# are the global fallbacks only — the per-market pool id, base /
# quote coin types, and scalars are written by the market creator
# (MarketCreator agent) at create time and read from the `markets`
# SQLite row. Leave these blank unless you are running a single-market
# demo that hard-codes a specific pool.
NEXT_PUBLIC_DEEPBOOK_POOL_ID=
NEXT_PUBLIC_DEEPBOOK_POOL_KEY=
NEXT_PUBLIC_DEEPBOOK_BASE_COIN_TYPE=
NEXT_PUBLIC_DEEPBOOK_QUOTE_COIN_TYPE=
NEXT_PUBLIC_DEEPBOOK_BASE_SCALAR=
NEXT_PUBLIC_DEEPBOOK_QUOTE_SCALAR=
# YES-side coin type + scalar. The markets/[id] page reads these to
# render the YES order book; defaults fall back to the bundled
# package id's `prediction_market::YES` and a 1_000_000 scalar. The
# `bootstrap-gamification` script writes these on first publish; a
# fresh deploy that skipped bootstrap will read the fallback and may
# display a different YES price than the on-chain pool.
NEXT_PUBLIC_DEEPBOOK_YES_COIN_TYPE=
NEXT_PUBLIC_DEEPBOOK_YES_COIN_SCALAR=
NEXT_PUBLIC_DEEPBOOK_QUOTE_COIN_SCALAR=

# Referral treasury (referral-keeper sweep target).
NEXT_PUBLIC_REFERRAL_TREASURY_ADDRESS=

# DEEP coin type (used to build the pool-creation fee coin). Default
# is the Mysten testnet DEEP at 0xDEEB…FBDD; override only for
# self-hosted deployments.
NEXT_PUBLIC_DEEP_TYPE=0xdeeb7a4f9e4cf1d11a3f5e8a87a162dee4f3a87a306b5b51e2bf9a7c9b8a8e7e::deep::DEEP

# Enoki (zkLogin) public client id. Required for the /auth flow.
# Get one at https://portal.enoki.mystenlabs.com.
NEXT_PUBLIC_ENOKI_API_KEY=

# Optional: Google OAuth client id for the /auth page's Google login.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Admin address (server-side admin actions check this against the
# connected wallet — set it to your deployer wallet to enable the
# /admin page's full set of cards). The page tolerates a missing or
# invalid value and renders admin forms disabled with a console
# warning.
NEXT_PUBLIC_ADMIN_ADDRESS=

# Sui network name (testnet | mainnet | devnet | localnet). Drives
# the explorer's per-network subdomain for tx links. Defaults to
# testnet if unset.
NEXT_PUBLIC_SUI_NETWORK=testnet
