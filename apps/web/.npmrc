# Mirrors repo root .npmrc — Vercel installs from apps/web, so the local
# override must include the same node-linker=hoisted setting or pnpm 10
# will fall back to isolated mode and `tsc` won't be on PATH for the
# SDK's `prepare` lifecycle.
node-linker=hoisted
shamefully-hoist=true
public-hoist-pattern[]=*
