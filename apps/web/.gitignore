# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (commit .env.example, ignore .env / .env.local)
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Workbox / PWA — Workbox was disabled in the R48 audit and the
# legacy /public/sw.js was a hand-rolled network-first cache that
# served 24h-stale HTML. The new /public/sw.js (added with UAT-FN-17)
# is the source of truth for the offline-shell SW and IS tracked
# below. The Workbox-generated files (sw.js.map, workbox-*.js) are
# no longer produced by the build and the ignore rules are kept as
# documentation for anyone grepping for the historical setup.
!/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
