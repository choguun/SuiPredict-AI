{
  "name": "@suipredict/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "test:wc": "node --import tsx --test tests/world-cup-fetcher.test.ts tests/world-cup-creator.test.ts tests/cursor-serialization.test.ts",
    "test:seed": "node --import tsx --test tests/wc-demo-seed.test.ts",
    "test:llm": "node --import tsx --test tests/llm-extractor.test.ts",
    "test": "node --import tsx --test tests/world-cup-fetcher.test.ts tests/llm-extractor.test.ts tests/world-cup-creator.test.ts tests/cursor-serialization.test.ts tests/wc-demo-seed.test.ts tests/world-cup-resolver.test.ts tests/team-analysis.test.ts",
    "bootstrap": "tsx scripts/bootstrap-gamification.ts",
    "bootstrap-parlay": "tsx scripts/bootstrap-parlay.ts",
    "resume-bootstrap": "tsx scripts/resume-bootstrap.ts",
    "verify-config": "tsx scripts/verify-config.ts",
    "rotate-prize-pubkey": "tsx scripts/rotate-prize-pubkey.ts",
    "rotate-prize-admin-address": "tsx scripts/rotate-prize-admin-address.ts",
    "postinstall": "node -e \"try { require('better-sqlite3'); } catch (e) { console.warn('[agents] better-sqlite3 native binding missing; run \\`pnpm rebuild better-sqlite3\\` to build it. This is required for the SQLite mirror and the WC demo seed.'); }\""
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "@noble/hashes": "^1.5.0",
    "@suipredict/sdk": "workspace:*",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@suipredict/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
