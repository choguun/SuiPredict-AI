# SuiPredict AI — Agents service env (apps/agents)
#
# Most keys live in the repo-root `.env`; this file is a per-service
# override that takes effect when you `cd apps/agents` and run
# `pnpm dev`. Leave it empty (or copy the root `.env.example` and trim
# to the keys below) to start.

# Required for the position-indexer / leaderboard-worker to run.
SUI_NETWORK=testnet
AGENT_POLICY_PACKAGE_ID=
STREAK_ADMIN_ID=
STREAK_REGISTRY_ID=
PRIZE_ADMIN_ID=
PRIZE_POOL_ID=
PARLAY_POOL_ID=
NEXT_PUBLIC_PARLAY_MAX_PAYOUT_BPS=50000
PARLAY_SEED_AMOUNT=0

# Hot wallet that signs the bootstrap and admin-withdraw txs.
AGENT_PRIVATE_KEY=

# HTTP port (default 3001).
PORT=3001

# Optional. Falls back to deterministic mock generators if blank.
OPENAI_API_KEY=
