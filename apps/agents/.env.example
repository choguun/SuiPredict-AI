# SuiPredict AI — Agents service env (apps/agents)
#
# Most keys live in the repo-root `.env`; this file is a per-service
# override that takes effect when you `cd apps/agents` and run
# `pnpm dev`. Leave it empty (or copy the root `.env.example` and trim
# to the keys below) to start.
#
# The boot validator in src/index.ts reads `required: true` entries
# and refuses to start if any are missing. If you see "Refusing to
# boot: N required env var(s) missing", the keys you need are:
#   AGENT_POLICY_PACKAGE_ID  — deployed package ID
#   DUSDC_TYPE               — full dUSDC type string (PTB generic arg)
#   MARKET_REGISTRY_ID       — MarketRegistry shared object
#   FEE_VAULT_ID             — FeeVault shared object
#   AGENT_POLICY_ID          — AgentPolicy shared object (created by
#                              `agent_policy::create_policy`)
#   PARLAY_POOL_ID           — ParlayPool shared object
# Re-run the bootstrap scripts to populate them automatically.

# Required for the position-indexer / leaderboard-worker to run.
SUI_NETWORK=testnet
AGENT_POLICY_PACKAGE_ID=
DUSDC_TYPE=
MARKET_REGISTRY_ID=
FEE_VAULT_ID=
STREAK_ADMIN_ID=
STREAK_REGISTRY_ID=
PRIZE_ADMIN_ID=
PRIZE_POOL_ID=
PARLAY_POOL_ID=
NEXT_PUBLIC_PARLAY_POOL_ID=
NEXT_PUBLIC_PARLAY_MAX_PAYOUT_BPS=50000
PARLAY_SEED_AMOUNT=0

# ProtocolVault<dUSDC> object id. Written by the bootstrap script and
# read by the vault-keeper worker + the verify-config script. The
# /vault page mirrors this same id under NEXT_PUBLIC_VAULT_OBJECT_ID.
VAULT_OBJECT_ID=

# AgentPolicy object id (created by `create_policy`). The agent
# workers use it to authorise on-chain calls. verify-config confirms
# it exists and matches `::agent_policy::AgentPolicy`.
AGENT_POLICY_ID=

# DeepBook BalanceManager (set by `bootstrap-gamification` after a
# `create_balance_manager` PTB, or filled in by the market-maker
# bot on first tick if blank). verify-config tolerates "skip" but a
# wrong id silently breaks all CLOB orders.
BALANCE_MANAGER_ID=

# Referral treasury — DeepBook order-fill rebates flow here via
# the referral-keeper sweep. Defaults to the deployer address if
# unset; the web bundle's NEXT_PUBLIC_REFERRAL_TREASURY_ADDRESS
# must match this exactly or the referral split will miss the
# intended recipient.
REFERRAL_TREASURY_ADDRESS=

# Admin gating — the web /admin page renders forms disabled unless
# the connected wallet equals this address. Bootstrap defaults this
# to the deployer; rotate it together with AGENT_PRIVATE_KEY if you
# hand off admin to a separate account.
NEXT_PUBLIC_ADMIN_ADDRESS=

# Prize-pool admin keypair (separate from AGENT_PRIVATE_KEY because
# `prize_pool::rotate_pubkey` is a privileged operation, and most
# operators isolate the prize-signing key from the agent hot wallet).
# Used by leaderboard-worker to sign claim attestations.
PRIZE_ADMIN_PRIVATE_KEY=

# ProfileRegistry shared object ID (read by the /profile/:addr REST
# route and the leaderboard worker's per-country breakdown).
NEXT_PUBLIC_PROFILE_REGISTRY_ID=

# Hot wallet that signs the bootstrap and admin-withdraw txs.
AGENT_PRIVATE_KEY=

# HTTP port (default 3001).
PORT=3001

# Optional. Falls back to deterministic mock generators if blank.
OPENAI_API_KEY=

# ─── R-WC-1.8: AutoFunder thresholds ────────────────────────────────────
# All three are optional — sensible defaults apply when blank:
#   - floor:  100 USDC (1e8 raw at 6 decimals)
#   - topup:  10,000 USDC (1e10 raw at 6 decimals)
#   - deep:   500 DEEP (5e8 raw at 6 decimals)
# Override any of these to raise/lower the auto-funding thresholds.
AUTO_FUNDER_MIN_DUSDC_ATOMS=
AUTO_FUNDER_TOPUP_DUSDC_ATOMS=
AUTO_FUNDER_MIN_DEEP_ATOMS=

# Optional cron overrides for the R-WC-1.8 agents (defaults shown).
AGENT_CRON_AUTO_FUNDER=*/10 * * * *
AGENT_CRON_POOL_PROVISIONER=*/15 * * * *
