# SuiPredict AI — Agents service env (apps/agents)
#
# Most keys live in the repo-root `.env`; this file is a per-service
# override that takes effect when you `cd apps/agents` and run
# `pnpm dev`. Leave it empty (or copy the root `.env.example` and trim
# to the keys below) to start.
#
# The boot validator in src/index.ts reads `required: true` entries
# and refuses to start if any are missing. If you see "Refusing to
# boot: N required env var(s) missing", the keys you need are:
#   AGENT_POLICY_PACKAGE_ID  — deployed package ID
#   DUSDC_TYPE               — full dUSDC type string (PTB generic arg)
#   MARKET_REGISTRY_ID       — MarketRegistry shared object
#   FEE_VAULT_ID             — FeeVault shared object
#   PARLAY_POOL_ID           — ParlayPool shared object
# Re-run the bootstrap scripts to populate them automatically.

# Required for the position-indexer / leaderboard-worker to run.
SUI_NETWORK=testnet
AGENT_POLICY_PACKAGE_ID=
DUSDC_TYPE=
MARKET_REGISTRY_ID=
FEE_VAULT_ID=
STREAK_ADMIN_ID=
STREAK_REGISTRY_ID=
PRIZE_ADMIN_ID=
PRIZE_POOL_ID=
PARLAY_POOL_ID=
NEXT_PUBLIC_PARLAY_MAX_PAYOUT_BPS=50000
PARLAY_SEED_AMOUNT=0

# ProfileRegistry shared object ID (read by the /profile/:addr REST
# route and the leaderboard worker's per-country breakdown).
NEXT_PUBLIC_PROFILE_REGISTRY_ID=

# Hot wallet that signs the bootstrap and admin-withdraw txs.
AGENT_PRIVATE_KEY=

# HTTP port (default 3001).
PORT=3001

# Optional. Falls back to deterministic mock generators if blank.
OPENAI_API_KEY=
