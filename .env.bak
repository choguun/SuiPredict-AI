# Web-only gamification object IDs (StreakAdmin, StreakRegistry, PrizePool,
# PrizeAdmin, FeeVault) are intentionally NOT in this file. The web reads
# them from `apps/web/.env.local`, which is updated by the bootstrap script.
# Keeping a second copy here invites drift — see plan-4 §11.

# Enoki / Google zkLogin — set via `sui login` portal or Mysten dashboard.
# Leave blank to disable zkLogin and use wallet-only flow.
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

STREAK_REGISTRY_ID=
STREAK_ADMIN_ID=
PRIZE_POOL_ID=
PRIZE_ADMIN_ID=
