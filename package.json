{
  "name": "suipredict-ai",
  "private": true,
  "scripts": {
    "predev": "bash ./scripts/dev-kill-zombies.sh",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@suipredict/web",
    "dev:agents": "turbo dev --filter=@suipredict/agents",
    "build": "turbo build",
    "lint": "turbo lint",
    "smoke-test": "pnpm --filter @suipredict/agents smoke-test",
    "contracts:build": "pnpm --filter @suipredict/contracts build",
    "contracts:test": "pnpm --filter @suipredict/contracts test",
    "test:sdk": "cd apps/agents && ./node_modules/.bin/tsx --test ../../packages/sdk/tests/*.test.ts",
    "test:agents": "cd apps/agents && ./node_modules/.bin/tsx --test tests/*.test.ts",
    "test:all": "pnpm test:wc && pnpm test:llm && pnpm test:seed && pnpm test:sdk && pnpm contracts:test",
    "dev:clean": "./scripts/dev-kill-zombies.sh && pnpm dev",
    "dev:web:clean": "./scripts/dev-kill-zombies.sh && pnpm dev:web",
    "dev:agents:clean": "./scripts/dev-kill-zombies.sh && pnpm dev:agents",
    "uat:clean": "./scripts/dev-kill-zombies.sh"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
