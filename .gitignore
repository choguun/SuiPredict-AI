node_modules
.next
.turbo
.env
.env.local
*.log
.DS_Store
packages/contracts/build
packages/contracts/Published.toml
**/data/*.db
/skills-main
plan.md

# DeepBook dependencies (build artifacts)
deps/deepbookv3/**/build/
deps/deepbookv3-self-hosted/**/build/

# DeepBook cloned repo (use as submodule or clone separately)
deps/deepbookv3/
deps/deepbookv3-self-hosted/

# Sui build outputs
*.mv
!*.move

# Local deployment outputs
.env.deployed*
.vercel

# Compiled output
**/tsconfig.tsbuildinfo

# Agents service dist (large; rebuilt on every deploy).
# The agents service is only run from source via `pnpm dev:agents`
# or rebuilt on deploy, so the dist does not need to be tracked.
apps/agents/dist/

# SQLite temp files
*.db-wal
*.db-shm
*.db-journal

# SDK dist (large; rebuilt by `pnpm --filter @suipredict/sdk build`).
# Was force-tracked previously to work around Railway's snapshot cache
# serving stale dist files; now that we always `railway up --detach`
# and `railpack.json`'s startCommand rebuilds the dist from src,
# tracking the dist is no longer needed (R-WC-3.3, 2026-06-19).
# Note: we ignore the *contents* (with `*`) but not the directory itself,
# so the dir + a .gitkeep marker stay tracked.
packages/sdk/dist/*
!packages/sdk/dist/.gitkeep
