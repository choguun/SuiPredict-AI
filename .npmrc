# R-Vercel-pnpm-fix: hoisted nodeLinker so that workspace package devDeps
# (notably `typescript` used by @suipredict/sdk's prepare lifecycle) get
# hoisted to the workspace root's node_modules/.bin and are reachable
# from `pnpm install`'s recursive exec contexts. Without this, pnpm 10's
# default `node-linker=isolated` puts each workspace's devDeps under
# `node_modules/.pnpm/<pkg>@<ver>/node_modules/...` and the SDK's
# `prepare: tsc` fails with "sh: line 1: tsc: command not found".
node-linker=hoisted
shamefully-hoist=true
public-hoist-pattern[]=*
